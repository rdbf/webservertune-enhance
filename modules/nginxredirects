#!/usr/bin/env python3
"""
nginxredirects
Syncs redirect rules from the Enhance htaccess API to per-domain Nginx
include files in /opt/webservertune-enhance/redirects/.
Triggered by inotify on /var/www/{uuid}/.htaccess and sites-enabled changes.
Called by webservertune-enhance main program.
"""

import json
import os
import re
import subprocess
import threading
import time
import urllib.request
import urllib.error
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor

SITES_DIR     = Path("/etc/nginx/sites-enabled")
REDIRECTS_DIR = Path("/opt/webservertune-enhance/redirects")
WWW_DIR       = Path("/var/www")
HTACCESS_FILE = ".htaccess"

UUID_RE = re.compile(
    r'[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}',
    re.IGNORECASE
)


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def watch(config, logger):
    """Entry point called by main program."""
    logger.info("nginxredirects starting")

    api           = config.get("api", {})
    api_url       = api.get("enhance_url", "").rstrip("/")
    master_org    = api.get("enhance_org_id", "")
    api_token     = api.get("enhance_token", "")
    general       = config.get("general", {})
    debounce_secs = general.get("debounce_seconds", 10)

    if not all([api_url, master_org, api_token]):
        logger.error("enhance_url, enhance_org_id, enhance_token must be set in [api]")
        return

    REDIRECTS_DIR.mkdir(parents=True, exist_ok=True)

    org_cache      = {}
    org_cache_lock = threading.Lock()

    known_uuids  = set()
    uuid_lock    = threading.Lock()
    # mutable container so the htaccess watcher loop can be restarted from other functions
    watcher_proc = [None]

    sites_debounce_timer = [None]
    sites_debounce_lock  = threading.Lock()


    # ---------------------------------------------------------------------------
    # API helpers
    # ---------------------------------------------------------------------------

    def _api_get(path):
        """Perform a GET request against the Enhance API and return parsed JSON, or None on error."""
        url = f"{api_url}{path}"
        req = urllib.request.Request(url, headers={"Authorization": f"Bearer {api_token}"})
        try:
            with urllib.request.urlopen(req, timeout=15) as resp:
                return json.loads(resp.read().decode())
        except urllib.error.HTTPError as e:
            logger.error(f"HTTP {e.code} for {url}")
            return None
        except Exception as e:
            logger.error(f"Request failed for {url}: {e}")
            return None

    def _build_org_cache():
        """
        Fetch all websites under the master org recursively and build a
        {website_id: org_id} mapping. Paginates until all websites are retrieved.
        """
        websites = {}
        offset   = 0
        limit    = 100

        while True:
            data = _api_get(
                f"/orgs/{master_org}/websites"
                f"?recursion=infinite&offset={offset}&limit={limit}"
            )
            if data is None:
                return
            for site in data.get("items", []):
                websites[site["id"]] = site["orgId"]
            total = data.get("total", 0)
            offset += limit
            if offset >= total:
                break

        with org_cache_lock:
            org_cache.clear()
            org_cache.update(websites)
        logger.info(f"Org cache built: {len(org_cache)} website(s)")

    def _get_org_id(uuid):
        """Return the org ID for a website UUID from the cache, or None if not found."""
        with org_cache_lock:
            return org_cache.get(uuid)


    # ---------------------------------------------------------------------------
    # Rule translation
    # ---------------------------------------------------------------------------

    def _extract_domain(cond_pattern):
        """Strip ^(www.)? prefix and $ suffix from a host condPattern to get the bare domain."""
        domain = re.sub(r'^\^\(www\.\)\?', '', cond_pattern)
        domain = re.sub(r'\$$', '', domain)
        return domain.strip()

    def _translate_rules(items):
        """
        Translate RewriteChain items to nginx return directives.
        Returns dict of domain -> list of rule strings.
        Rules with query string conditions are skipped — nginx has no equivalent.
        """
        rules_by_domain = {}

        for item in items:
            conds = item.get("conds", [])
            rule  = item.get("rule", {})

            host_cond = next((c for c in conds if c.get("testString") == "%{HTTP_HOST}"), None)
            uri_cond  = next((c for c in conds if c.get("testString") == "%{REQUEST_URI}"), None)

            if not host_cond:
                logger.warning(f"Skipping rule with missing host condition: {item}")
                continue

            domain = _extract_domain(host_cond["condPattern"])
            flags  = rule.get("flags", [])
            code   = next((f.split("=")[1] for f in flags if f.startswith("R=")), "301")

            if not uri_cond:
                target = rule.get("substitution", "").replace("%{REQUEST_URI}", "$request_uri")
                if domain not in rules_by_domain:
                    rules_by_domain[domain] = []
                rules_by_domain[domain].append(
                    f"location ~ ^(?!/.well-known)(.*)$ {{\n"
                    f"    return {code} {target};\n"
                    f"}}"
                )
                continue

            pattern = uri_cond["condPattern"]

            if "?" in pattern:
                logger.warning(
                    f"[{domain}] Skipping '{pattern}' — "
                    f"query string conditions are not supported in Nginx"
                )
                continue

            target = rule.get("substitution", "").replace("%{REQUEST_URI}", "$1")

            if domain not in rules_by_domain:
                rules_by_domain[domain] = []

            rules_by_domain[domain].append(
                f"location ~ ^{pattern}(.*)$ {{\n"
                f"    return {code} {target};\n"
                f"}}"
            )

        return rules_by_domain


    # ---------------------------------------------------------------------------
    # File writing and nginx reload
    # ---------------------------------------------------------------------------

    def _write_conf(domain, rules):
        """
        Write redirect conf file for a domain.
        Returns True if the file content changed, False otherwise.
        """
        path    = REDIRECTS_DIR / f"{domain}.conf"
        content = "\n".join(rules) + "\n" if rules else ""
        try:
            existing = path.read_text() if path.exists() else None
            if existing == content:
                return False
            path.write_text(content)
            logger.info(f"[{domain}] Written {len(rules)} redirect(s)")
            return True
        except Exception as e:
            logger.error(f"[{domain}] Failed to write conf: {e}")
            return False

    def _reload_nginx():
        """Test nginx config and reload if valid. Logs and skips reload if test fails."""
        try:
            test = subprocess.run(["nginx", "-t"], capture_output=True, text=True)
            if test.returncode != 0:
                logger.error(f"nginx -t failed, reload skipped: {test.stderr.strip()}")
                return
        except Exception as e:
            logger.error(f"Failed to run nginx -t: {e}")
            return
        try:
            result = subprocess.run(
                ["systemctl", "reload", "nginx"], capture_output=True, text=True
            )
            if result.returncode == 0:
                logger.info("nginx reloaded")
            else:
                logger.error(f"nginx reload failed: {result.stderr.strip()}")
        except Exception as e:
            logger.error(f"Failed to reload nginx: {e}")


    # ---------------------------------------------------------------------------
    # Vhost helpers
    # ---------------------------------------------------------------------------

    def _extract_uuid_from_conf(cf):
        """Extract site UUID from the Enhance-generated access_log line in a vhost conf."""
        try:
            for line in cf.read_text().splitlines():
                s = line.strip()
                if "access_log /var/local/enhance/webserver_logs/" in s:
                    parts = s.split()
                    if len(parts) >= 2:
                        return parts[1].split("/")[-1].replace(".log", "")
        except Exception:
            pass
        return None

    def _site_confs():
        """Return all vhost conf files, excluding the control panel 000- prefix and default.conf."""
        return [
            f for f in SITES_DIR.glob("*.conf")
            if not f.name.startswith("000-") and f.name != "default.conf"
        ]

    def _domains_for_uuid(uuid):
        """Return set of domain names (vhost stems) that map to a given UUID."""
        domains = set()
        for cf in _site_confs():
            if _extract_uuid_from_conf(cf) == uuid:
                domains.add(cf.stem)
        return domains


    # ---------------------------------------------------------------------------
    # Sync a single UUID
    # ---------------------------------------------------------------------------

    def _sync_uuid(uuid):
        """
        Fetch redirect rules for a UUID, translate, and write per-domain conf files.
        Returns True if any file changed.
        """
        org_id = _get_org_id(uuid)
        if not org_id:
            logger.debug(f"[{uuid}] Org not found, skipping sync")
            return False

        data = _api_get(f"/orgs/{org_id}/websites/{uuid}/htaccess")
        if data is None:
            return False

        rules_by_domain = _translate_rules(data.get("items", []))
        domains         = _domains_for_uuid(uuid)
        changed         = False

        for domain in domains:
            rules = rules_by_domain.get(domain, [])
            if _write_conf(domain, rules):
                changed = True

        return changed


    # ---------------------------------------------------------------------------
    # UUID registration for .htaccess watching
    # ---------------------------------------------------------------------------

    def _register_uuid(uuid):
        """Register a UUID for .htaccess watching, restarting the watcher to pick up the new path."""
        with uuid_lock:
            if uuid in known_uuids:
                return
            known_uuids.add(uuid)
        logger.debug(f"Registered UUID for .htaccess watch: {uuid}")
        _restart_htaccess_watcher()

    def _restart_htaccess_watcher():
        """Terminate the running inotifywait process so the htaccess watcher loop restarts it."""
        proc = watcher_proc[0]
        if proc is not None:
            try:
                proc.terminate()
            except Exception:
                pass


    # ---------------------------------------------------------------------------
    # .htaccess watcher
    # ---------------------------------------------------------------------------

    def _htaccess_watcher_loop():
        """
        Watch for CLOSE_WRITE and CREATE on .htaccess across all registered webspace directories.
        Restarts inotifywait whenever a new UUID is registered via _restart_htaccess_watcher().
        """
        while True:
            with uuid_lock:
                paths = [str(WWW_DIR / u) for u in known_uuids if (WWW_DIR / u).exists()]

            if not paths:
                time.sleep(5)
                continue

            cmd = [
                "inotifywait", "--monitor", "--quiet",
                "--format", "%w %e %f",
                "--event", "close_write",
                "--event", "create",
            ] + paths

            try:
                proc = subprocess.Popen(
                    cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True
                )
                watcher_proc[0] = proc
            except Exception as e:
                logger.error(f"Failed to start htaccess inotifywait: {e}")
                time.sleep(5)
                continue

            for line in proc.stdout:
                parts = line.strip().split(" ", 2)
                if len(parts) != 3:
                    continue
                watch_dir, _, filename = parts
                if filename != HTACCESS_FILE:
                    continue
                m = UUID_RE.search(watch_dir)
                if not m:
                    continue
                uuid = m.group(0)
                logger.info(f"[{uuid}] .htaccess changed, syncing redirects")
                if _sync_uuid(uuid):
                    _reload_nginx()

            proc.wait()
            watcher_proc[0] = None
            logger.debug("htaccess inotifywait exited, restarting")
            time.sleep(1)


    # ---------------------------------------------------------------------------
    # sites-enabled watcher
    # ---------------------------------------------------------------------------

    def _on_sites_changed():
        """
        Rescan sites-enabled. Create empty conf files for new domains,
        remove conf files for domains no longer present.
        """
        current_domains = set()
        for cf in _site_confs():
            domain = cf.stem
            current_domains.add(domain)
            conf = REDIRECTS_DIR / f"{domain}.conf"
            if not conf.exists():
                _write_conf(domain, [])
                uuid = _extract_uuid_from_conf(cf)
                if uuid:
                    _register_uuid(uuid)
                    if _sync_uuid(uuid):
                        _reload_nginx()

        for conf in REDIRECTS_DIR.glob("*.conf"):
            if conf.stem not in current_domains:
                try:
                    conf.unlink()
                    logger.info(f"Removed stale redirect conf: {conf.name}")
                except Exception as e:
                    logger.error(f"Failed to remove {conf.name}: {e}")

    def _sites_watcher_loop():
        """Watch sites-enabled for vhost additions and removals, triggering a debounced rescan."""
        cmd = [
            "inotifywait", "--monitor", "--quiet",
            "--format", "%e %f",
            "--event", "create",
            "--event", "delete",
            "--event", "moved_to",
            str(SITES_DIR),
        ]
        while True:
            try:
                logger.info(f"Watching {SITES_DIR} for vhost changes")
                proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, text=True)
            except FileNotFoundError:
                logger.error("inotifywait not found — install inotify-tools: apt install inotify-tools")
                return
            except Exception as e:
                logger.error(f"Failed to start sites inotifywait: {e}")
                time.sleep(5)
                continue

            for line in proc.stdout:
                parts = line.strip().split(" ", 1)
                if len(parts) != 2:
                    continue
                event, fname = parts
                if not fname.endswith(".conf") or fname.startswith("000-") or fname == "default.conf":
                    continue

                if "CREATE" in event or "MOVED_TO" in event:
                    domain = Path(fname).stem
                    conf   = REDIRECTS_DIR / f"{domain}.conf"
                    if not conf.exists():
                        _write_conf(domain, [])
                        logger.debug(f"Created empty conf for new vhost: {domain}")

                with sites_debounce_lock:
                    if sites_debounce_timer[0] is not None:
                        sites_debounce_timer[0].cancel()
                    t = threading.Timer(debounce_secs / 2, _on_sites_changed)
                    sites_debounce_timer[0] = t
                    t.start()

            ret = proc.wait()
            logger.warning(f"sites inotifywait exited (code {ret}), restarting in 5s")
            time.sleep(5)


    # ---------------------------------------------------------------------------
    # Startup
    # ---------------------------------------------------------------------------

    def _startup():
        """
        Clear existing redirect confs, build the org cache, register all current
        vhosts, and sync redirect rules for all sites in parallel.
        """
        try:
            for f in REDIRECTS_DIR.glob("*.conf"):
                f.unlink()
            logger.info("Cleared existing redirect conf files")
        except Exception as e:
            logger.error(f"Failed to clear redirects dir: {e}")

        for cf in _site_confs():
            _write_conf(cf.stem, [])

        _build_org_cache()

        site_uuids = []
        for cf in _site_confs():
            uuid = _extract_uuid_from_conf(cf)
            if not uuid:
                continue
            _register_uuid(uuid)
            site_uuids.append(uuid)

        changed_flags = []
        changed_lock  = threading.Lock()

        def sync_one(uuid):
            if _sync_uuid(uuid):
                with changed_lock:
                    changed_flags.append(True)

        with ThreadPoolExecutor(max_workers=5) as executor:
            executor.map(sync_one, site_uuids)

        if changed_flags:
            _reload_nginx()

        logger.info("Startup sync complete")


    # ---------------------------------------------------------------------------
    # Start
    # ---------------------------------------------------------------------------

    threading.Thread(target=_htaccess_watcher_loop, daemon=True).start()
    threading.Thread(target=_sites_watcher_loop, daemon=True).start()
    _startup()

    while True:
        time.sleep(60)
