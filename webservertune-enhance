#!/usr/bin/env python3
"""
webservertune-enhance
Detects the active webserver and starts the appropriate modules.
Monitors for webserver changes and restarts via systemd if detected.
"""

import importlib.util
import logging
import os
import subprocess
import sys
import threading
import time
from pathlib import Path

BASE_DIR    = Path("/opt/webservertune-enhance")
CONFIG_FILE = BASE_DIR / "settings.conf"
LOG_DIR     = Path("/var/log/webservertune-enhance")
MODULES_DIR = BASE_DIR / "modules"

# seconds between webserver change detection polls
DETECT_INTERVAL = 30


def load_config():
    """Load and parse settings.conf. Exits on missing file or TOML error."""
    try:
        import tomllib
    except ImportError:
        print("ERROR: tomllib not available. Requires Python 3.11+", file=sys.stderr)
        sys.exit(1)
    try:
        with open(CONFIG_FILE, "rb") as f:
            return tomllib.load(f)
    except FileNotFoundError:
        print(f"ERROR: Config file not found: {CONFIG_FILE}", file=sys.stderr)
        sys.exit(1)
    except tomllib.TOMLDecodeError as e:
        print(f"ERROR: Failed to parse config: {e}", file=sys.stderr)
        sys.exit(1)


def setup_logger(name, log_level):
    """Create a named logger writing to both a log file and stdout."""
    log_file = LOG_DIR / f"{name}.log"
    logger   = logging.getLogger(name)
    level    = getattr(logging, log_level.upper(), logging.INFO)
    logger.setLevel(level)

    if not logger.handlers:
        fmt = logging.Formatter(
            "%(asctime)s %(levelname).1s %(message)s",
            datefmt="%Y-%m-%d %H:%M:%S"
        )
        fh = logging.FileHandler(log_file)
        fh.setFormatter(fmt)
        sh = logging.StreamHandler(sys.stdout)
        sh.setFormatter(fmt)
        logger.addHandler(fh)
        logger.addHandler(sh)

    return logger


def is_active(service):
    """Return True if the systemd service is running or in a transitional state."""
    result = subprocess.run(
        ["systemctl", "is-active", service],
        capture_output=True, text=True
    )
    return result.stdout.strip() in ("active", "reloading", "activating", "deactivating")


def is_enabled(service):
    """Return True if the systemd service is enabled."""
    result = subprocess.run(
        ["systemctl", "is-enabled", service],
        capture_output=True, text=True
    )
    return result.stdout.strip() == "enabled"


def detect_webserver():
    """
    Return 'nginx', 'ols', or None based on enabled and active state.
    is-enabled is the primary signal for intent; is-active confirms current state.
    """
    if is_enabled("nginx"):
        return "nginx"
    if is_enabled("lshttpd"):
        return "ols"
    return None


def _wait_for_ols_active(config, logger):
    """Poll until lshttpd is strictly active before starting OLS modules."""
    debounce_secs = config.get("general", {}).get("debounce_seconds", 10)
    for attempt in range(1, 11):
        result = subprocess.run(
            ["systemctl", "is-active", "lshttpd"],
            capture_output=True, text=True
        )
        state = result.stdout.strip()
        if state == "active":
            logger.info(f"OLS confirmed active after {attempt} check(s)")
            return
        logger.debug(f"OLS readiness check {attempt}/10: {state}")
        time.sleep(debounce_secs)
    logger.warning("OLS did not reach active state after 10 checks — proceeding anyway")


def load_module(name):
    """Dynamically load a module from the modules directory by filename."""
    from importlib.machinery import SourceFileLoader
    path   = MODULES_DIR / name
    loader = SourceFileLoader(name, str(path))
    spec   = importlib.util.spec_from_loader(name, loader)
    mod    = importlib.util.module_from_spec(spec)
    loader.exec_module(mod)
    return mod


def main():
    """
    Entry point. Detects the active webserver, loads and starts the appropriate
    modules as daemon threads, then monitors for webserver changes and config
    file updates, exiting to trigger a systemd restart when either occurs.
    """
    if os.geteuid() != 0:
        print("ERROR: Must be run as root", file=sys.stderr)
        sys.exit(1)

    LOG_DIR.mkdir(parents=True, exist_ok=True)

    config    = load_config()
    log_level = config.get("general", {}).get("log_level", "WARNING")
    logger    = setup_logger("webservertune-enhance", log_level)

    logger.info("webservertune-enhance starting")

    webserver = detect_webserver()
    if webserver is None:
        logger.error("No supported webserver detected (nginx or lshttpd). Exiting.")
        sys.exit(1)

    logger.info(f"Detected webserver: {webserver}")

    # shared API client — instantiated once, passed to all modules that need it
    enhanceapi = load_module("enhanceapi")
    api_logger = setup_logger("enhanceapi", log_level)
    api_client = enhanceapi.EnhanceAPI(config, api_logger)
    api_client.build_org_cache(api_logger)

    if webserver == "nginx":
        if not is_active("nginx"):
            logger.warning("nginx is enabled but not active — running cleanup and attempting start")
            nginxtune    = load_module("nginxtune")
            nginx_logger = setup_logger("nginxtune", log_level)
            nginxtune.cleanup(nginx_logger)
            subprocess.run(["systemctl", "start", "nginx"], capture_output=True)
            if not is_active("nginx"):
                logger.error("nginx did not start after cleanup. Exiting.")
                sys.exit(1)
            logger.info("nginx started after cleanup")

        nginxtune    = load_module("nginxtune")
        nginx_logger = setup_logger("nginxtune", log_level)

        t = threading.Thread(
            target=nginxtune.watch,
            args=(config, nginx_logger),
            daemon=True
        )
        t.start()

        if config.get("nginx-fastcgiclear", {}).get("enabled", False):
            fastcgiclear = load_module("fastcgiclear")
            fcc_logger   = setup_logger("fastcgiclear", log_level)
            t_fcc        = threading.Thread(
                target=fastcgiclear.watch,
                args=(config, fcc_logger, api_client),
                daemon=True
            )
            t_fcc.start()

        if config.get("general", {}).get("nginx_redirects", False):
            nginxredirects = load_module("nginxredirects")
            redir_logger   = setup_logger("nginxredirects", log_level)
            t_redir        = threading.Thread(
                target=nginxredirects.watch,
                args=(config, redir_logger, api_client),
                daemon=True
            )
            t_redir.start()

    elif webserver == "ols":
        _wait_for_ols_active(config, logger)

        olstune    = load_module("olstune")
        ols_logger = setup_logger("olstune", log_level)

        # OLSSiteWatcher is a shared inotify-based site registry; must be started before
        # any module that registers consumers against it
        site_watcher = olstune.OLSSiteWatcher(ols_logger)
        site_watcher.start()

        t1 = threading.Thread(
            target=olstune.watch,
            args=(config, ols_logger, site_watcher),
            daemon=True
        )
        t1.start()

        if config.get("general", {}).get("ols_503fix_enable", False):
            ols503fix  = load_module("ols503fix")
            fix_logger = setup_logger("ols503fix", log_level)
            t2 = threading.Thread(
                target=ols503fix.run,
                args=(config, fix_logger, site_watcher, api_client),
                daemon=True
            )
            t2.start()

        if config.get("ols-lsapi", {}).get("enabled", False):
            olslsapi     = load_module("olslsapi")
            lsapi_logger = setup_logger("olslsapi", log_level)
            t_lsapi      = threading.Thread(
                target=olslsapi.run,
                args=(config, lsapi_logger, site_watcher, api_client),
                daemon=True
            )
            t_lsapi.start()

        olsredirects     = load_module("olsredirects")
        ols_redir_logger = setup_logger("olsredirects", log_level)
        olsredirects.cleanup(config, ols_redir_logger)

        if config.get("general", {}).get("ols_redirects", False):
            t3 = threading.Thread(
                target=olsredirects.watch,
                args=(config, ols_redir_logger, api_client),
                daemon=True
            )
            t3.start()

    # independent of webserver — runs on both nginx and ols
    if config.get("cf-api-health", {}).get("enabled", False):
        cfapihealth = load_module("cfapihealth")
        cfa_logger  = setup_logger("cfapihealth", log_level)
        t_cfa       = threading.Thread(
            target=cfapihealth.run,
            args=(config, cfa_logger, api_client),
            daemon=True
        )
        t_cfa.start()

    def watch_config():
        """Watch for settings.conf changes and exit so systemd restarts the service."""
        cmd = [
            "inotifywait", "--monitor", "--quiet",
            "--format", "%e %f",
            "--event", "modify",
            "--event", "create",
            "--event", "moved_to",
            str(CONFIG_FILE.parent),
        ]
        try:
            proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, text=True)
        except FileNotFoundError:
            logger.error("inotifywait not found — install inotify-tools: apt install inotify-tools")
            return
        for line in proc.stdout:
            parts = line.strip().split(" ", 1)
            if len(parts) == 2 and parts[1] == CONFIG_FILE.name:
                logger.warning("settings.conf changed, exiting for systemd restart")
                logging.shutdown()
                os._exit(0)

    threading.Thread(target=watch_config, daemon=True).start()

    while True:
        time.sleep(DETECT_INTERVAL)
        current = detect_webserver()
        if current != webserver:
            logger.warning(
                f"Webserver changed from {webserver} to {current or 'none'}. "
                "Exiting for systemd restart."
            )
            sys.exit(0)


if __name__ == "__main__":
    main()
