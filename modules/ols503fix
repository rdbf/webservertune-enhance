#!/usr/bin/env python3
"""
ols503fix
Monitors per-site webserver logs and restarts PHP via the Enhance API
when 503 error thresholds are exceeded.
Called by webservertune-enhance main program.
"""

import re
import threading
import time
from collections import deque

import requests

LOG_DIR     = "/var/local/enhance/webserver_logs"
LOG_PATTERN = re.compile(r'"([^"]*)"')


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def run(config, logger, site_watcher, api_client):
    """Entry point called by main program."""
    cfg = config.get("ols-503fix", {})

    logger.info(
        f"ols503fix starting — window={cfg.get('window_seconds', 30)}s, "
        f"min_503={cfg.get('min_503_count', 5)}, "
        f"last_n={cfg.get('last_n_requests', 10)}, "
        f"min_pct={cfg.get('min_503_percent', 50)}%, "
        f"cooldown={cfg.get('cooldown_seconds', 60)}s"
    )

    registry = SiteRegistry(cfg, logger, api_client)
    site_watcher.register_consumer(registry.add_site, registry.remove_site)

    while True:
        registry.process()
        time.sleep(cfg.get("scan_interval", 1))


# ---------------------------------------------------------------------------
# Log parsing
# ---------------------------------------------------------------------------

def _parse_status(line):
    """Extract the HTTP status code from a quoted-field log line. Returns None if unparseable."""
    matches = LOG_PATTERN.findall(line)
    if len(matches) >= 4:
        try:
            return int(matches[3])
        except ValueError:
            pass
    return None


# ---------------------------------------------------------------------------
# Site state
# ---------------------------------------------------------------------------

class SiteState:
    """Tracks request and 503 error history for a single site within configurable time windows."""

    def __init__(self, website_id, config):
        self.website_id     = website_id
        self.config         = config
        self.all_requests   = deque()
        self.errors_503     = deque()
        # separate 24h deque so long-term counts survive the short sliding window prune
        self.errors_503_24h = deque()
        self.last_restart   = 0.0

    def record(self, status_code):
        """Record a request, appending timestamp to the relevant deques."""
        now = time.time()
        self.all_requests.append(now)
        if status_code == 503:
            self.errors_503.append(now)
            self.errors_503_24h.append(now)

    def _prune(self, now):
        """Remove entries outside the sliding window and 24h window from all deques."""
        cutoff = now - self.config.get("window_seconds", 30)
        while self.all_requests and self.all_requests[0] < cutoff:
            self.all_requests.popleft()
        while self.errors_503 and self.errors_503[0] < cutoff:
            self.errors_503.popleft()
        cutoff_24h = now - 86400
        while self.errors_503_24h and self.errors_503_24h[0] < cutoff_24h:
            self.errors_503_24h.popleft()

    def count_24h(self):
        """Return the number of 503 errors recorded in the last 24 hours."""
        now = time.time()
        cutoff = now - 86400
        while self.errors_503_24h and self.errors_503_24h[0] < cutoff:
            self.errors_503_24h.popleft()
        return len(self.errors_503_24h)

    def should_restart(self, logger):
        """
        Evaluate whether a PHP restart should be triggered.
        Returns (trigger, total_requests, error_count, error_percent).
        Restart is suppressed if within the cooldown period.
        """
        now = time.time()
        self._prune(now)

        total  = len(self.all_requests)
        errors = len(self.errors_503)

        logger.debug(f"[{self.website_id}] window: {total} total, {errors} x 503")

        if errors < self.config.get("min_503_count", 5):
            return False, total, errors, 0

        # evaluate the percentage of 503s among the last N requests
        last_n  = self.config.get("last_n_requests", 10)
        recent  = list(self.all_requests)[-last_n:]
        if not recent:
            return False, total, errors, 0

        recent_503 = sum(1 for t in self.errors_503 if t >= recent[0])
        pct        = recent_503 / len(recent) * 100

        logger.debug(
            f"[{self.website_id}] last {len(recent)} requests: {recent_503} x 503 ({pct:.0f}%)"
        )

        if pct < self.config.get("min_503_percent", 50):
            return False, total, errors, pct

        cooldown = self.config.get("cooldown_seconds", 60)
        if now - self.last_restart < cooldown:
            logger.debug(
                f"[{self.website_id}] threshold met but in cooldown "
                f"({cooldown - (now - self.last_restart):.0f}s remaining)"
            )
            return False, total, errors, pct

        return True, total, errors, pct

    def mark_restarted(self):
        """Record restart time and clear request history to reset the sliding window."""
        self.last_restart = time.time()
        self.all_requests.clear()
        self.errors_503.clear()


# ---------------------------------------------------------------------------
# File watcher
# ---------------------------------------------------------------------------

class FileWatcher:
    """Tail a log file, handling rotation and truncation."""

    def __init__(self, path, logger, seek_to_end_on_open=True):
        self.path                = path
        self.logger              = logger
        self.seek_to_end_on_open = seek_to_end_on_open
        self.fh                  = None
        self.inode               = None
        self.position            = 0
        self._open()

    def _open(self):
        """Open the file and record its inode. Seeks to end if seek_to_end_on_open is set."""
        try:
            self.fh = open(self.path, "r", errors="replace")
            self.inode = __import__("os").fstat(self.fh.fileno()).st_ino
            if self.seek_to_end_on_open:
                self.fh.seek(0, 2)
            self.position = self.fh.tell()
            self.logger.debug(f"Opened: {self.path} (inode {self.inode})")
        except OSError:
            self.fh    = None
            self.inode = None

    def _reopen_if_needed(self):
        """Reopen the file if it has been rotated (inode changed) or truncated."""
        import os
        try:
            stat = os.stat(self.path)
        except OSError:
            if self.fh:
                self.fh.close()
                self.fh    = None
                self.inode = None
            return

        if self.fh is None:
            self._open()
            return

        if stat.st_ino != self.inode:
            self.logger.debug(f"Recreated: {self.path}")
            self.fh.close()
            self._open()
            return

        if stat.st_size < self.position:
            self.logger.debug(f"Truncated: {self.path}")
            self.fh.seek(0)
            self.position = 0

    def readlines(self):
        """Return any new lines written since the last read."""
        self._reopen_if_needed()
        if self.fh is None:
            return []
        lines         = self.fh.readlines()
        self.position = self.fh.tell()
        return lines

    def close(self):
        if self.fh:
            self.fh.close()


# ---------------------------------------------------------------------------
# Site registry
# ---------------------------------------------------------------------------

class SiteRegistry:
    """Manages per-site FileWatcher and SiteState instances, driven by OLSSiteWatcher callbacks."""

    def __init__(self, config, logger, api_client):
        self.config      = config
        self.logger      = logger
        self._api_client = api_client
        self.watchers    = {}
        self.states      = {}
        self._lock       = threading.Lock()

    def add_site(self, wid):
        """Register a new site, creating a FileWatcher and SiteState for it."""
        import os
        with self._lock:
            if wid in self.watchers:
                return
            self.logger.debug(f"New site: {wid}")
            path = os.path.join(LOG_DIR, f"{wid}.log")
            self.watchers[wid] = FileWatcher(path, self.logger)
            self.states[wid]   = SiteState(wid, self.config)

    def remove_site(self, wid):
        """Deregister a site and close its file handle."""
        with self._lock:
            if wid not in self.watchers:
                return
            self.logger.debug(f"Site removed: {wid}")
            self.watchers[wid].close()
            del self.watchers[wid]
            del self.states[wid]

    def process(self):
        """Read new log lines for all sites and evaluate restart thresholds."""
        with self._lock:
            snapshot = [
                (wid, self.watchers[wid], self.states[wid])
                for wid in list(self.watchers)
            ]

        for wid, watcher, state in snapshot:
            before = len(state.errors_503_24h)

            for line in watcher.readlines():
                line = line.strip()
                if not line:
                    continue
                status = _parse_status(line)
                if status is not None:
                    state.record(status)

            after = state.count_24h()
            if after > before:
                self.logger.info(f"[{wid}] 503 count last 24h: {after}")

            trigger, total, errors, pct = state.should_restart(self.logger)
            if trigger:
                self.logger.info(
                    f"[{wid}] Thresholds met — {errors} x 503 in "
                    f"{self.config.get('window_seconds', 30)}s window, "
                    f"{pct:.0f}% of last {self.config.get('last_n_requests', 10)} requests"
                )
                domain = self._api_client.get_primary_domain(wid, self.logger)
                if domain is not None:
                    probe = _probe_site(domain)
                    if probe is not None:
                        self.logger.info(f"[{wid}] Probe of {domain} returned {probe} — " +
                            ("site is responding normally, skipping restart" if probe in (200, 301, 302)
                             else "triggering PHP restart"))
                        if probe in (200, 301, 302):
                            continue
                    else:
                        self.logger.info(f"[{wid}] Probe of {domain} timed out — triggering PHP restart")
                self.logger.info(f"[{wid}] Restarting PHP")
                success = _restart_php(wid, self._api_client, self.logger)
                state.mark_restarted()
                if success:
                    self.logger.info(f"[{wid}] PHP restart confirmed")
                else:
                    self.logger.error(f"[{wid}] PHP restart FAILED — will retry after cooldown")


# ---------------------------------------------------------------------------
# Enhance API
# ---------------------------------------------------------------------------

def _restart_php(website_id, api_client, logger):
    """Trigger a PHP restart for the website via the Enhance API. Returns True on success."""
    resp = api_client.post_with_response(f"/v2/websites/{website_id}/restart_php", {}, logger)
    if resp is None:
        return False
    if resp.status_code == 200:
        return True
    logger.error(
        f"[{website_id}] API restart_php returned {resp.status_code}: {resp.text[:200]}"
    )
    return False


# ---------------------------------------------------------------------------
# Site probe
# ---------------------------------------------------------------------------

def _probe_site(domain):
    """
    Make a cachebust GET request to the site to verify its actual response.
    Returns the final HTTP status code, or None on timeout/connection error.
    """
    import random
    url = f"https://{domain}/?probe={random.randint(1, 999999)}"
    try:
        resp = requests.get(url, timeout=3, allow_redirects=True)
        return resp.status_code
    except requests.RequestException:
        return None
